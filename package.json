{
  "name": "ai-smart-community-system",
  "version": "1.0.0",
  "description": "AI-based Smart Community Problem Detection System with Express API, Flask AI service, and MongoDB Atlas",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "build:glass": "esbuild src/frontend/liquidGlassBridge.jsx --bundle --format=iife --platform=browser --target=es2020 --minify --outfile=public/liquid-glass-react.js",
    "start:ai": "python ai_service/app.py",
    "start:stt": "python stt_service/app.py",
    "seed": "node scripts/seedDatabase.js",
    "seed:fresh": "node scripts/seedDatabase.js --fresh",
    "cities:sync": "node scripts/syncCityRegistry.js",
    "routing:sync": "node scripts/syncRoutingRegistry.js",
    "migrate:cities": "node scripts/migrateComplaintCities.js",
    "verify:city-registry": "node scripts/verifyCityRegistry.js",
    "verify:multi-city-phase2": "node scripts/verifyMultiCityPhase2.js",
    "verify:multi-city-phase3": "node scripts/verifyMultiCityPhase3.js",
    "verify:multi-city-phase4": "node scripts/verifyMultiCityPhase4.js",
    "verify:multi-city-phase5": "node scripts/verifyMultiCityPhase5.js",
    "verify:multi-city-phase6": "node scripts/verifyMultiCityPhase6.js",
    "verify:multi-city-phase7": "node scripts/verifyMultiCityPhase7.js",
    "verify:multi-city-phase8": "node scripts/verifyMultiCityPhase8.js",
    "verify:multi-city-phase9": "node scripts/verifyMultiCityPhase9.js",
    "verify:production-integration": "node scripts/verifyProductionIntegration.js",
    "verify:ai-service-auth": "python3 scripts/verifyAiServiceAuth.py",
    "verify:smtp": "node scripts/verifySmtp.js",
    "verify:resolution": "node scripts/verifyResolutionLoop.js",
    "verify:civic-intelligence": "node scripts/verifyCivicIntelligence.js",
    "dataset:validate": "python3 scripts/manageBenchmarkDataset.py validate",
    "dataset:stats": "python3 scripts/manageBenchmarkDataset.py stats",
    "dataset:split": "python3 scripts/manageBenchmarkDataset.py split",
    "verify:dataset": "python3 scripts/verifyBenchmarkDataset.py",
    "evaluate:benchmark": "python3 scripts/evaluateBenchmark.py",
    "evaluate:benchmark:readiness": "python3 scripts/evaluateBenchmark.py --allow-empty",
    "verify:metrics": "python3 scripts/verifyBenchmarkMetrics.py",
    "verify:human-review": "node scripts/verifyHumanReview.js",
    "verify:decision-audit": "node scripts/verifyDecisionAudit.js",
    "verify:observability": "node scripts/verifyAiObservability.js",
    "benchmark:compare": "python3 scripts/compareBenchmarkReports.py",
    "verify:benchmark-comparison": "python3 scripts/verifyBenchmarkComparison.py",
    "verify:authority-tickets": "node scripts/verifyAuthorityTickets.js",
    "verify:accessibility": "node scripts/verifyAccessibility.js",
    "verify:resilience": "node scripts/verifyResilience.js",
    "verify:load": "node scripts/verifyLoad.js",
    "verify:syntax": "node scripts/verifyProjectSyntax.js",
    "verify:release": "node scripts/verifyReleaseReadiness.js",
    "evaluate:ai": "node scripts/evaluateAi.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "liquid-glass-react": "^1.1.1",
    "mongoose": "^8.13.2",
    "nodemailer": "^9.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "keywords": [
    "smart-community",
    "nlp",
    "computer-vision",
    "iot",
    "dashboard",
    "express",
    "flask",
    "mongodb-atlas"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
