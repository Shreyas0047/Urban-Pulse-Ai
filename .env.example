NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/urban-pulse
JWT_SECRET=replace_with_at_least_32_random_characters
CORS_ORIGIN=http://localhost:3000
ALLOW_ROLE_TOKEN_ISSUE=false

AI_SERVICE_URL=http://127.0.0.1:5000
AI_SERVICE_TOKEN=replace_with_the_same_32_character_secret_on_both_services
AI_SERVICE_REQUIRE_TOKEN=false
AI_SERVICE_TIMEOUT_MS=110000
AI_MAX_REQUEST_BYTES=4194304

# Florence runs independently on Cloud Run. Gemini is the visual fallback.
VISION_PROVIDER_ORDER=florence,gemini
VISION_FALLBACK_ENABLED=true
FLORENCE_REMOTE_ENABLED=true
FLORENCE_SERVICE_URL=
FLORENCE_SERVICE_TOKEN=
FLORENCE_ALLOW_HTTP=false
FLORENCE_TIMEOUT_SECONDS=50
FLORENCE_MAX_RETRIES=1
FLORENCE_REMOTE_CACHE_SIZE=128
FLORENCE_MAX_TRANSMIT_BYTES=1500000
FLORENCE_REMOTE_MAX_IMAGE_DIMENSION=1280
FLORENCE_CIRCUIT_FAILURE_THRESHOLD=3
FLORENCE_CIRCUIT_COOLDOWN_SECONDS=60

# Gemini is used only for visual observations. Keep this key on the AI service.
GEMINI_VISION_ENABLED=true
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=25
GEMINI_MAX_RETRIES=1
GEMINI_RATE_LIMIT_PER_MINUTE=10
GEMINI_CACHE_SIZE=128
GEMINI_MAX_IMAGE_DIMENSION=1280
GEMINI_JPEG_QUALITY=82
GEMINI_MAX_TRANSMIT_BYTES=1500000

# In-process Florence must remain disabled on Render. The remote service replaces it.
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
VISION_MODEL_NAME=sentence-transformers/clip-ViT-B-32
FLORENCE_ENABLED=false
FLORENCE_MODEL_NAME=microsoft/Florence-2-base-ft
FLORENCE_MODEL_REVISION=58c9f97c2a8448696851e2cc95eb1b6919493fe4
FLORENCE_LAZY_LOAD=true
FLORENCE_WARMUP=false
FLORENCE_OBJECT_DETECTION=false
FLORENCE_INFERENCE_TIMEOUT_SECONDS=90
FLORENCE_QUEUE_TIMEOUT_SECONDS=8
FLORENCE_MAX_IMAGE_DIMENSION=768
FLORENCE_MAX_NEW_TOKENS=128
FLORENCE_NUM_BEAMS=1
FLORENCE_CACHE_SIZE=8
FLORENCE_RETRY_COOLDOWN_SECONDS=300
VISION_CLIP_FALLBACK_ENABLED=false
VISION_CLIP_SECONDARY_ENABLED=false
VISION_CONFIDENCE_THRESHOLD=0.24
VISION_IMAGE_WEIGHT=0.38
EMBEDDING_MODEL_ENABLED=false
VISION_MAX_IMAGE_BYTES=2097152
VISION_MAX_IMAGE_PIXELS=12000000
VISION_DECODE_MAX_DIMENSION=2048
TEXT_CONFIDENCE_THRESHOLD=0.26
CONTEXT_REPEAT_HIGH=5
CONTEXT_REPEAT_MEDIUM=3
AI_MEMORY_BUDGET_MB=512
AI_MEMORY_RESERVE_MB=160
AI_MEMORY_CLEANUP_ENABLED=true
MALLOC_ARENA_MAX=2
OMP_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_FAMILY=4
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
BBMP_EMAIL_TO=comm@bbmp.gov.in

WEATHERSTACK_API_KEY=
WEATHERSTACK_BASE_URL=http://api.weatherstack.com
WEATHERSTACK_ENABLED=true
WEATHERSTACK_MONTHLY_LIMIT=90
ZENSERP_API_KEY=
ZENSERP_BASE_URL=https://app.zenserp.com/api/v2/search
ZENSERP_ENABLED=true
ZENSERP_MONTHLY_LIMIT=48

AUTHORITY_ADAPTER=disabled
AUTHORITY_TICKET_EMAIL=
AUTHORITY_WEBHOOK_URL=
AUTHORITY_WEBHOOK_TOKEN=
AUTHORITY_TIMEOUT_MS=8000
AUTHORITY_MAX_ATTEMPTS=3
